# Image tags — set by CI/CD pipeline to git SHA
ORCHESTRATOR_IMAGE_TAG=latest
QUERY_IMAGE_TAG=latest
TELEGRAM_IMAGE_TAG=latest

# Service URLs (non-secret compose configuration)
TELEGRAM_SERVICE_URL=http://telegram:8082
QUERY_SERVICE_URL=http://query:8081

# All runtime secrets are in /etc/clive/secrets.env (injected by Ansible)
# This file is for non-secret compose configuration only
# Never put secret values in this file

# Local development reminder — copy to .env and populate secrets.env separately
# Required secrets (never commit real values):
#   TELEGRAM_BOT_TOKEN=
#   TELEGRAM_OWNER_CHAT_ID=
#   ANTHROPIC_API_KEY=
#   POSTGRES_PASSWORD=
#   APP_DB_PASSWORD=
#   AUDIT_WRITER_PASSWORD=
#   MINIO_ROOT_USER=
#   MINIO_ROOT_PASSWORD=
