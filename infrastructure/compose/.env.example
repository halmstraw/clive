# Image tags — set by CI/CD pipeline to git SHA
ORCHESTRATOR_IMAGE_TAG=latest
QUERY_IMAGE_TAG=latest
TELEGRAM_IMAGE_TAG=latest
PROCESSING_IMAGE_TAG=latest

# Service URLs (non-secret compose configuration)
TELEGRAM_SERVICE_URL=http://telegram:8082
QUERY_SERVICE_URL=http://query:8081
PROCESSING_SERVICE_URL=http://processing:8083
MINIO_RAW_BUCKET=clive-raw-store

# Block 20 — Cost/Rate Management (D-125, v0.6)
# Optional daily LLM spend cap in USD.
# When set and today's cumulative spend reaches this value, Block 8 returns
# a canned response and skips the LLM call. Resets at midnight UTC.
# Leave blank (or remove) to disable the cap entirely.
# Example: DAILY_SPEND_CAP_USD=10.00
# DAILY_SPEND_CAP_USD=

# Optional inbound rate limit: maximum queries per UTC clock hour.
# When set and the count is reached, Block 23 rejects further queries for
# that hour with a polite message. Counter resets at the top of each hour.
# Leave blank (or remove) for no limit.
# Example: RATE_LIMIT_QUERIES_PER_HOUR=60
# RATE_LIMIT_QUERIES_PER_HOUR=

# Block 9 v0.7 — Web search action (search_handler.py)
# SEARCH_API_KEY goes in /etc/clive/secrets.env — never commit real values here
# SEARCH_API_PROVIDER selects the provider: brave (default) or serpapi
# SEARCH_API_PROVIDER=brave

# Block 23 v0.7 — Timezone for reminder intent time parsing (bot.py)
# Uses IANA timezone names. Defaults to UTC if unset.
# Example: CLIVE_TIMEZONE=Europe/London
# CLIVE_TIMEZONE=UTC

# All runtime secrets are in /etc/clive/secrets.env (injected by Ansible)
# This file is for non-secret compose configuration only
# Never put secret values in this file

# Local development reminder — copy to .env and populate secrets.env separately
# Required secrets (never commit real values):
#   TELEGRAM_BOT_TOKEN=
#   TELEGRAM_OWNER_CHAT_ID=
#   ANTHROPIC_API_KEY=
#   OPENAI_API_KEY=
#   POSTGRES_PASSWORD=
#   APP_DB_PASSWORD=
#   AUDIT_WRITER_PASSWORD=
#   MINIO_ROOT_USER=
#   MINIO_ROOT_PASSWORD=
#   GRAFANA_ADMIN_PASSWORD=
#   GOOGLE_CLIENT_ID=
#   GOOGLE_CLIENT_SECRET=
#   SEARCH_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
