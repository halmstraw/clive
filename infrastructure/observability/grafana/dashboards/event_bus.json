{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "CLIVE event bus — live feed of events routed through Block 13 (D-131)",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "tags": ["clive", "system"],
      "title": "System Overview",
      "tooltip": "Back to system overview",
      "type": "dashboards",
      "url": "/d/clive-system-overview"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "${loki_datasource}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Event Bus — Dispatched Events",
      "type": "logs",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki_datasource}"
          },
          "expr": "{container=\"clive-orchestrator\"} | json | event=\"event_dispatched\" | line_format \"{{.event_type}} | src={{.source_block}} | conv={{.conversation_id}} | payload={{.payload_keys}}\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${loki_datasource}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "title": "Bus Errors — Alignment Rejections & Delivery Failures",
      "type": "logs",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki_datasource}"
          },
          "expr": "{container=\"clive-orchestrator\"} | json | level=~\"warning|error\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": [
    "clive",
    "events"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "CLIVE Event Bus",
  "uid": "clive-event-bus",
  "version": 1
}
